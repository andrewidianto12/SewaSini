{
  "info": {
    "_postman_id": "7d7d0b16-5a6b-4b0b-8c3f-8a1f0d0d1a01",
    "name": "SewaSini - User API",
    "description": "Postman collection for SewaSini user endpoints.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Register User",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"budi@example.com\",\n  \"nama_lengkap\": \"Budi Santoso\",\n  \"ttl\": \"1998-05-20\",\n  \"no_hp\": \"+6281234567890\",\n  \"password\": \"rahasia123\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/users/register",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "users",
            "register"
          ]
        },
        "event": [
          {
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "const response = pm.response.json();",
                "if (response && response.id) {",
                "  pm.environment.set('userId', response.id);",
                "}",
                "if (response && response.email) {",
                "  pm.environment.set('email', response.email);",
                "}"
              ]
            }
          }
        ]
      }
    },
    {
      "name": "Login User",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"budi@example.com\",\n  \"password\": \"rahasia123\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/users/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "users",
            "login"
          ]
        },
        "event": [
          {
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "const response = pm.response.json();",
                "if (response && response.access_token) {",
                "  pm.environment.set('accessToken', response.access_token);",
                "}",
                "if (response && response.token_type) {",
                "  pm.environment.set('tokenType', response.token_type);",
                "}",
                "if (response && response.user && response.user.id) {",
                "  pm.environment.set('userId', response.user.id);",
                "}",
                "if (response && response.user && response.user.email) {",
                "  pm.environment.set('email', response.user.email);",
                "}"
              ]
            }
          }
        ]
      }
    },
    {
      "name": "Send OTP",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"budi@example.com\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/users/send-otp",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "users",
            "send-otp"
          ]
        }
      }
    },
    {
      "name": "Verify OTP",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"budi@example.com\",\n  \"otp_code\": \"123456\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/users/verify-otp",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "users",
            "verify-otp"
          ]
        }
      }
    },
    {
      "name": "List Users",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/users",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "users"
          ]
        }
      }
    },
    {
      "name": "Get User By ID",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/users/{{userId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "users",
            "{{userId}}"
          ]
        }
      }
    },
    {
      "name": "Update User",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"budi.baru@example.com\",\n  \"nama_lengkap\": \"Budi Santoso Baru\",\n  \"ttl\": \"1998-05-20\",\n  \"no_hp\": \"+6281234567000\",\n  \"password\": \"passwordbaru\",\n  \"role\": \"user\",\n  \"is_verified\": true\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/users/{{userId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "users",
            "{{userId}}"
          ]
        }
      }
    },
    {
      "name": "Delete User",
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/users/{{userId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "users",
            "{{userId}}"
          ]
        }
      }
    }
  ]
}
