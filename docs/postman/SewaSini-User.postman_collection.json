  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"nama_lengkap\": \"Budi Santoso\",\n  \"ttl\": \"1998-05-20\",\n  \"no_hp\": \"+6281234567890\",\n  \"password\": \"rahasia123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/users/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "users",
                "register"
              ]
            },
            "event": [
              {
                "listen": "test",
                "script": {
                  "type": "text/javascript",
                  "exec": [
                    "const response = pm.response.json();",
                    "if (response && response.id) {",
                    "  pm.environment.set('userId', response.id);",
                    "}",
                    "if (response && response.email) {",
                    "  pm.environment.set('email', response.email);",
                    "}"
                  ]
                }
              }
            ]
          }
        },
        {
          "name": "Send OTP",
          "request": {
            "method": "POST",
